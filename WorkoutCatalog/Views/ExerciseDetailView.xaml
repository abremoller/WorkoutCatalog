<UserControl x:Class="WorkoutCatalog.Views.ExerciseDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WorkoutCatalog.ViewModels"
             xmlns:models="clr-namespace:WorkoutCatalog.Models"
             xmlns:converters="clr-namespace:WorkoutCatalog.Converters"
             d:DataContext="{d:DesignInstance vm:ExerciseDetailViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <converters:DurationToStringConverter x:Key="DurationConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisConverter"/>
        <converters:StarConverter x:Key="StarConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
        <StackPanel MaxWidth="900">
            <!-- Back Button -->
            <Button Content="Back"
                    HorizontalAlignment="Left"
                    Command="{Binding GoBackCommand}"
                    Margin="0,0,0,16"/>

            <!-- Exercise Header -->
            <TextBlock Text="{Binding Exercise.Name}"
                       FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"
                       Margin="0,0,0,12"/>

            <!-- Metadata Section -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="4" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <!-- Display mode -->
                    <WrapPanel Margin="0,0,0,8"
                               Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}, ConverterParameter=Invert}">
                        <TextBlock Margin="0,0,24,0" VerticalAlignment="Center">
                            <Run Text="Type: " Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Run Text="{Binding CurrentType, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Margin="0,0,24,0" VerticalAlignment="Center">
                            <Run Text="Level: " Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Run Text="{Binding CurrentLevel, Mode=OneWay}"/>
                        </TextBlock>
                        <Button Content="Edit"
                                Command="{Binding EditCommand}"
                                VerticalAlignment="Center"/>
                    </WrapPanel>

                    <!-- Edit mode -->
                    <WrapPanel Margin="0,0,0,8"
                               Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}}">
                        <StackPanel Orientation="Horizontal" Margin="0,0,24,8">
                            <TextBlock Text="Type:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox SelectedValue="{Binding CurrentType}"
                                      SelectedValuePath="Tag"
                                      Width="130">
                                <ComboBoxItem Content="Unknown" Tag="{x:Static models:ExerciseType.Unknown}"/>
                                <ComboBoxItem Content="Stretching" Tag="{x:Static models:ExerciseType.Stretching}"/>
                                <ComboBoxItem Content="Strength" Tag="{x:Static models:ExerciseType.Strength}"/>
                                <ComboBoxItem Content="Core" Tag="{x:Static models:ExerciseType.Core}"/>
                                <ComboBoxItem Content="Meditation" Tag="{x:Static models:ExerciseType.Meditation}"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,24,8">
                            <TextBlock Text="Level:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox SelectedValue="{Binding CurrentLevel}"
                                      SelectedValuePath="Tag"
                                      Width="140">
                                <ComboBoxItem Content="Unknown" Tag="{x:Static models:ExerciseLevel.Unknown}"/>
                                <ComboBoxItem Content="Beginner" Tag="{x:Static models:ExerciseLevel.Beginner}"/>
                                <ComboBoxItem Content="Intermediate" Tag="{x:Static models:ExerciseLevel.Intermediate}"/>
                                <ComboBoxItem Content="Expert" Tag="{x:Static models:ExerciseLevel.Expert}"/>
                            </ComboBox>
                        </StackPanel>
                        <Button Content="Save"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveMetadataCommand}"
                                VerticalAlignment="Center"/>

                        <Button Content="Rescan Folder"
                            Margin="8,0,0,0"
                            Command="{Binding RescanFolderCommand}"
                            VerticalAlignment="Center"/>
                    </WrapPanel>

                        <TextBlock Text="{Binding RescanStatusMessage}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"
                               Visibility="{Binding RescanStatusMessage, Converter={StaticResource NullToVisConverter}}"/>

                    <WrapPanel>
                        <TextBlock Margin="0,0,24,0">
                            <Run Text="Full:" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Run Text="{Binding Exercise.FullDurationSeconds, Converter={StaticResource DurationConverter}, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock>
                            <Run Text="Preview:" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Run Text="{Binding Exercise.PreviewDurationSeconds, Converter={StaticResource DurationConverter}, Mode=OneWay}"/>
                        </TextBlock>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Info image -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="4" Padding="16" Margin="0,0,0,12"
                    Visibility="{Binding Exercise.HasImage, Converter={StaticResource BoolToVisConverter}}">
                <StackPanel>
                    <TextBlock Text="Info Image"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>

                    <Border BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8"
                            Background="{StaticResource CardBrush}"
                            HorizontalAlignment="Stretch"
                            Cursor="Hand"
                            ToolTip="Double-click to open full screen"
                            MouseLeftButtonDown="InfoImage_MouseLeftButtonDown">
                        <Image Source="{Binding ImagePath}"
                               Stretch="Uniform"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Top"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Description -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="4" Padding="16" Margin="0,0,0,12"
                    Visibility="{Binding Exercise.HasDescription, Converter={StaticResource BoolToVisConverter}}">
                <StackPanel>
                    <TextBlock Text="Description"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding Exercise.Description}"
                               TextWrapping="Wrap"
                               LineHeight="22"/>
                </StackPanel>
            </Border>

            <!-- Rating -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="4" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8">
                        <Run Text="Rating"/>
                        <Run Text="{Binding CurrentRating, StringFormat=' ({0}/10)', Mode=OneWay}"
                             Foreground="{StaticResource StarBrush}"/>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding SetRatingCommand}" CommandParameter="1"
                                FontSize="22" Padding="2,2" Background="Transparent" BorderBrush="Transparent" Cursor="Hand">
                            <TextBlock Text="{Binding CurrentRating, Converter={StaticResource StarConverter}, ConverterParameter=1}"
                                       Foreground="{StaticResource StarBrush}"/>
                        </Button>
                        <Button Command="{Binding SetRatingCommand}" CommandParameter="2"
                                FontSize="22" Padding="2,2" Background="Transparent" BorderBrush="Transparent" Cursor="Hand">
                            <TextBlock Text="{Binding CurrentRating, Converter={StaticResource StarConverter}, ConverterParameter=2}"
                                       Foreground="{StaticResource StarBrush}"/>
                        </Button>
                        <Button Command="{Binding SetRatingCommand}" CommandParameter="3"
                                FontSize="22" Padding="2,2" Background="Transparent" BorderBrush="Transparent" Cursor="Hand">
                            <TextBlock Text="{Binding CurrentRating, Converter={StaticResource StarConverter}, ConverterParameter=3}"
                                       Foreground="{StaticResource StarBrush}"/>
                        </Button>
                        <Button Command="{Binding SetRatingCommand}" CommandParameter="4"
                                FontSize="22" Padding="2,2" Background="Transparent" BorderBrush="Transparent" Cursor="Hand">
                            <TextBlock Text="{Binding CurrentRating, Converter={StaticResource StarConverter}, ConverterParameter=4}"
                                       Foreground="{StaticResource StarBrush}"/>
                        </Button>
                        <Button Command="{Binding SetRatingCommand}" CommandParameter="5"
                                FontSize="22" Padding="2,2" Background="Transparent" BorderBrush="Transparent" Cursor="Hand">
                            <TextBlock Text="{Binding CurrentRating, Converter={StaticResource StarConverter}, ConverterParameter=5}"
                                       Foreground="{StaticResource StarBrush}"/>
                        </Button>
                        <Button Command="{Binding SetRatingCommand}" CommandParameter="6"
                                FontSize="22" Padding="2,2" Background="Transparent" BorderBrush="Transparent" Cursor="Hand">
                            <TextBlock Text="{Binding CurrentRating, Converter={StaticResource StarConverter}, ConverterParameter=6}"
                                       Foreground="{StaticResource StarBrush}"/>
                        </Button>
                        <Button Command="{Binding SetRatingCommand}" CommandParameter="7"
                                FontSize="22" Padding="2,2" Background="Transparent" BorderBrush="Transparent" Cursor="Hand">
                            <TextBlock Text="{Binding CurrentRating, Converter={StaticResource StarConverter}, ConverterParameter=7}"
                                       Foreground="{StaticResource StarBrush}"/>
                        </Button>
                        <Button Command="{Binding SetRatingCommand}" CommandParameter="8"
                                FontSize="22" Padding="2,2" Background="Transparent" BorderBrush="Transparent" Cursor="Hand">
                            <TextBlock Text="{Binding CurrentRating, Converter={StaticResource StarConverter}, ConverterParameter=8}"
                                       Foreground="{StaticResource StarBrush}"/>
                        </Button>
                        <Button Command="{Binding SetRatingCommand}" CommandParameter="9"
                                FontSize="22" Padding="2,2" Background="Transparent" BorderBrush="Transparent" Cursor="Hand">
                            <TextBlock Text="{Binding CurrentRating, Converter={StaticResource StarConverter}, ConverterParameter=9}"
                                       Foreground="{StaticResource StarBrush}"/>
                        </Button>
                        <Button Command="{Binding SetRatingCommand}" CommandParameter="10"
                                FontSize="22" Padding="2,2" Background="Transparent" BorderBrush="Transparent" Cursor="Hand">
                            <TextBlock Text="{Binding CurrentRating, Converter={StaticResource StarConverter}, ConverterParameter=10}"
                                       Foreground="{StaticResource StarBrush}"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Video -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="4" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Video"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="▶ Play Preview"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,8,0"
                                Command="{Binding PlayPreviewCommand}"
                                IsEnabled="{Binding Exercise.HasPreviewVideo}"/>
                        <Button Content="▶ Play Full"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding PlayFullCommand}"
                                IsEnabled="{Binding Exercise.HasFullVideo}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Thumbnail -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="4" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Thumbnail"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,10"/>

                    <!-- Current thumbnail preview -->
                    <Border Background="{StaticResource CardBrush}"
                            Width="160" Height="100"
                            HorizontalAlignment="Left"
                            CornerRadius="3"
                            Margin="0,0,0,10"
                            ClipToBounds="True">
                        <Grid>
                            <TextBlock Text="No thumbnail"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       Visibility="{Binding ThumbnailBitmap, Converter={StaticResource NullToVisConverter}, ConverterParameter=Invert}"/>
                            <Image Source="{Binding ThumbnailBitmap}"
                                   Stretch="UniformToFill"
                                   Visibility="{Binding ThumbnailBitmap, Converter={StaticResource NullToVisConverter}}"/>
                        </Grid>
                    </Border>

                    <!-- Actions -->
                    <WrapPanel>
                        <Button Content="Upload Image"
                                Command="{Binding SetThumbnailFromFileCommand}"
                                Margin="0,0,8,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Capture at" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Content="-1s"
                                Command="{Binding StepCaptureTimeCommand}"
                                CommandParameter="-1"
                                Margin="0,0,6,0"/>
                            <TextBox Text="{Binding CaptureTimeSeconds, UpdateSourceTrigger=PropertyChanged}"
                                     Width="52" VerticalAlignment="Center"/>
                            <Button Content="+1s"
                                Command="{Binding StepCaptureTimeCommand}"
                                CommandParameter="1"
                                Margin="6,0,0,0"/>
                            <TextBlock Text="s" VerticalAlignment="Center" Margin="4,0,8,0"/>
                            <Button Content="Capture"
                                    Command="{Binding CaptureThumbnailCommand}"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Playlists -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="4" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Playlists"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>

                    <!-- Current playlists -->
                    <ItemsControl ItemsSource="{Binding ExercisePlaylists}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource CardBrush}"
                                        CornerRadius="4"
                                        Padding="8,6" Margin="0,0,0,4">
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right"
                                                Content="X"
                                                Command="{Binding DataContext.RemoveFromPlaylistCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Id}"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                Foreground="{StaticResource ErrorBrush}"
                                                Padding="4,2" FontSize="11"
                                                VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Add to playlist -->
                    <DockPanel Margin="0,6,0,0">
                        <Button DockPanel.Dock="Right"
                                Content="Add"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding AddToPlaylistCommand}"
                                Margin="8,0,0,0"/>
                        <ComboBox ItemsSource="{Binding AllPlaylists}"
                                  SelectedItem="{Binding SelectedPlaylistToAdd}"
                                  DisplayMemberPath="Name"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Comments -->
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="4" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Comments"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>

                    <!-- Existing Comments -->
                    <ItemsControl ItemsSource="{Binding Comments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource CardBrush}"
                                        CornerRadius="4"
                                        Padding="12" Margin="0,0,0,8">
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right"
                                                Content="X"
                                                Command="{Binding DataContext.DeleteCommentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Id}"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                Foreground="{StaticResource ErrorBrush}"
                                                VerticalAlignment="Top"
                                                Padding="4,2"
                                                FontSize="11"/>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat='yyyy-MM-dd HH:mm'}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="11" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Add Comment -->
                    <DockPanel Margin="0,4,0,0">
                        <Button DockPanel.Dock="Right"
                                Content="Add"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding AddCommentCommand}"
                                Margin="8,0,0,0"
                                VerticalAlignment="Top"/>
                        <TextBox Text="{Binding NewCommentText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="80"
                                 VerticalContentAlignment="Top"
                                 VerticalScrollBarVisibility="Auto"/>
                    </DockPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
