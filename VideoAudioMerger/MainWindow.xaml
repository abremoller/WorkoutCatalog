<Window x:Class="VideoAudioMerger.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Video Audio Merger" Height="650" Width="950"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Video Audio Merger" 
                   FontSize="24" FontWeight="Bold" 
                   Margin="0,0,0,20"/>

        <GroupBox Grid.Row="1" Header="Project Name" Padding="10" Margin="0,0,0,15">
            <TextBox x:Name="ProjectNameTextBox" Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="5"/>
        </GroupBox>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Auto-Populate from Folder" Padding="10" Margin="0,0,0,15">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBox x:Name="FolderPathTextBox" Grid.Column="0" 
                                     Text="{Binding FolderPath}" IsReadOnly="True" Padding="5" VerticalAlignment="Center"/>
                            <Button x:Name="BrowseFolderButton" Grid.Column="1" Content="Browse Folder" 
                                    Command="{Binding BrowseFolderCommand}"
                                    Padding="15,5" Margin="10,0" Background="#4CAF50" Foreground="White"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="File Selection" Padding="10" Margin="0,0,0,15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Full Video:" 
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="FullVideoTextBox"
                                 Text="{Binding FullVideoPath}" AllowDrop="True"
                                 Padding="5" Margin="0,0,0,10"/>
                        <Button Grid.Row="0" Grid.Column="2" x:Name="BrowseFullVideoButton" Content="Browse..." 
                                Command="{Binding BrowseFullVideoCommand}"
                                Padding="10,5" Margin="10,0,0,10"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Full Audio:" 
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="FullAudioTextBox"
                                 Text="{Binding FullAudioPath}" AllowDrop="True"
                                 Padding="5" Margin="0,0,0,10"/>
                        <Button Grid.Row="1" Grid.Column="2" x:Name="BrowseFullAudioButton" Content="Browse..." 
                                Command="{Binding BrowseFullAudioCommand}"
                                Padding="10,5" Margin="10,0,0,10"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Preview Video:" 
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="PreviewVideoTextBox"
                                 Text="{Binding PreviewVideoPath}" AllowDrop="True"
                                 Padding="5" Margin="0,0,0,10"/>
                        <Button Grid.Row="2" Grid.Column="2" x:Name="BrowsePreviewVideoButton" Content="Browse..." 
                                Command="{Binding BrowsePreviewVideoCommand}"
                                Padding="10,5" Margin="10,0,0,10"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Preview Audio:" 
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="PreviewAudioTextBox"
                                 Text="{Binding PreviewAudioPath}" AllowDrop="True"
                                 Padding="5"/>
                        <Button Grid.Row="3" Grid.Column="2" x:Name="BrowsePreviewAudioButton" Content="Browse..." 
                                Command="{Binding BrowsePreviewAudioCommand}"
                                Padding="10,5" Margin="10,0,0,0"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Output Folder" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox x:Name="OutputFolderTextBox" Grid.Column="0" 
                                 Text="{Binding OutputFolder}"
                                 Padding="5" VerticalAlignment="Center"/>
                        <Button x:Name="BrowseOutputButton" Grid.Column="1" Content="Browse..." 
                                Command="{Binding BrowseOutputFolderCommand}"
                                Padding="10,5" Margin="10,0,0,0"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Info.txt (Description)" Padding="10" Margin="0,15,0,0">
                    <TextBox x:Name="InfoTextBox" 
                             Text="{Binding InfoText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" 
                             TextWrapping="Wrap" 
                             VerticalScrollBarVisibility="Auto"
                             MinHeight="80" 
                             Padding="5"/>
                </GroupBox>

                <GroupBox Header="Info.png (Paste Image from Clipboard)" Padding="10" Margin="0,15,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Border x:Name="ImageBorder" Grid.Row="0" 
                                BorderBrush="#CCC" BorderThickness="2" 
                                Background="#F5F5F5" MinHeight="150"
                                AllowDrop="True">
                            <Image x:Name="InfoImage" 
                                   Source="{Binding InfoImageSource}"
                                   Stretch="Uniform"
                                   Margin="5"/>
                        </Border>
                        
                        <Button x:Name="PasteImageButton" Grid.Row="1" 
                                Content="Paste Image from Clipboard" 
                                Command="{Binding PasteImageCommand}"
                                Padding="10,5" Margin="0,10,0,0" 
                                HorizontalAlignment="Center"/>
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="3" Background="#E0E0E0" Padding="10" Margin="0,15,0,0">
            <TextBlock x:Name="StatusTextBlock" Text="{Binding StatusMessage}" FontWeight="SemiBold"/>
        </Border>

        <Button x:Name="ProcessButton" Grid.Row="4" Content="Process Videos" 
                Command="{Binding ProcessCommand}"
                FontSize="16" FontWeight="Bold"
                Padding="20,10" Margin="0,15,0,0"
                Background="#2196F3" Foreground="White"/>
    </Grid>
</Window>
